# ═══════════════════════════════════════════════════════════════════════════
# Document Agent — Environment Variables
# Copy this file to .env and fill in your keys
# ═══════════════════════════════════════════════════════════════════════════

# ── REQUIRED ──────────────────────────────────────────────────────────────
# OpenAI API key (used for GPT-4.1, GPT-4.1-mini)
OPENAI_API_KEY=sk-your-openai-key-here

# ── OPTIONAL ──────────────────────────────────────────────────────────────
# OpenAI-only is the default. Set to "true" only if you want Bedrock/Claude.
USE_BEDROCK=false

# AWS Bedrock (only needed if USE_BEDROCK=true)
# AWS_ACCESS_KEY_ID=your-aws-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret
# AWS_REGION=us-east-1

# Tavily web search (optional — enables web search toggle in UI)
# TAVILY_API_KEY=tvly-your-tavily-key

# Runtime storage directories (optional)
# Relative paths are resolved from the repository root.
# NOTEBOOK_AGENT_UPLOAD_DIR=uploads
# NOTEBOOK_AGENT_EXPORT_DIR=exports
# NOTEBOOK_AGENT_SNAPSHOT_DIR=snapshot
# NOTEBOOK_AGENT_MEMORY_DIR=memory
# NOTEBOOK_AGENT_CHAT_DIR=chats
# NOTEBOOK_AGENT_CONVERSATION_DIR=inmemory_conversation

# Langfuse observability (optional)
# LANGFUSE_HOST=https://cloud.langfuse.com
# LANGFUSE_PUBLIC_KEY=pk-your-key
# LANGFUSE_SECRET_KEY=sk-your-key
